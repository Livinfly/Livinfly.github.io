&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="kn">from&lt;/span> &lt;span class="nn">PyQt5.QtWidgets&lt;/span> &lt;span class="kn">import&lt;/span> &lt;span class="n">QApplication&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="n">QLabel&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="n">QWidget&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="n">QGridLayout&lt;/span>
